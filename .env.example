# Hisaab — environment variables
#
# Copy this file to apps/web/.env.local and fill in real values.
# NEVER commit a file containing a real key. .gitignore already excludes .env*.

# --- Phase 2 & 3: server-side classification + PDF ingestion ---
# Required for live Claude classification (/api/classify) and PDF extraction (/api/ingest).
# Without it, the app still runs on sample data using built-in fallback categories.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Phase 4 (NOT built yet): persistence + accounts ---
# Provisioned later when wiring Supabase/Postgres. Left here as documentation only.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
